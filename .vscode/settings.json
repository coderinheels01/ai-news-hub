{
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    
    // Pylance settings for import suggestions
    "python.languageServer": "Pylance",
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.autoSearchPaths": true,
    "python.analysis.extraPaths": [
        "${workspaceFolder}/app",
        "${workspaceFolder}/app/scrapers",
        "${workspaceFolder}/app/services"
    ],
    "python.analysis.completeFunctionParens": true,
    "python.analysis.importFormat": "absolute",
    "python.analysis.indexing": true,
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.variableTypes": true,
    "python.analysis.diagnosticMode": "workspace",
    "python.analysis.useLibraryCodeForTypes": true,
    
    // Ruff configuration
    "ruff.enable": true,
    "ruff.lint.enable": true,
    "ruff.format.enable": true,
    "ruff.lint.preview": true,
    "ruff.lint.select": ["E", "W", "I"],  // Remove "F" to disable Pyflakes (F821 errors)
    "ruff.lint.ignore": ["F821"],  // Also ignore undefined name errors
    
    // Editor settings for suggestions
    "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": false
    },
    "editor.suggestOnTriggerCharacters": true,
    "editor.acceptSuggestionOnEnter": "on",
    "editor.hover.enabled": "on",
    "editor.parameterHints.enabled": true,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggest.showClasses": true,
    "editor.suggest.showFunctions": true,
    "editor.suggest.showModules": true,
    "editor.suggest.showKeywords": true,
    "editor.suggest.showSnippets": true,
    "editor.suggest.showUsers": true,
    "editor.suggest.showValues": true,
    "editor.suggest.showVariables": true,
    
    // Disable other linters that might conflict
    "python.linting.enabled": true,
    "python.linting.pylintEnabled": false,
    "python.linting.flake8Enabled": false,
    "python.linting.mypyEnabled": false,
    "python.linting.pycodestyleEnabled": false,
    "python.linting.pydocstyleEnabled": false,
    "python.linting.banditEnabled": false
}